{
  "name": "hyperfuel-geofencing-analytics",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cd apps/api && .venv/bin/uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:web": "cd apps/web && npm run dev",
    "install:all": "cd apps/api && pip install -e \".[dev]\" && cd ../web && npm install",
    "build:web": "cd apps/web && npm run build",
    "test": "cd apps/api && pytest tests -q"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
