# Supabase — copy from Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Set false (or remove) to read/write your Supabase tables.
# true = empty in-memory store — dashboard will show no users even if Supabase has data.
USE_MEMORY_STORE=false

API_HOST=0.0.0.0
API_PORT=8000
DEFAULT_STATION_RADIUS_METERS=70
APP_VERSION=1.0.0
